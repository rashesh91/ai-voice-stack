# Copy this file to .env and fill in your real values
# chmod 600 .env

# Sarvam.ai — Indian language STT/TTS
# Get from: https://dashboard.sarvam.ai
SARVAM_API_KEY=sk_your_sarvam_api_key_here

# LiveKit self-hosted — generate any random key/secret pair
# Key: 16+ alphanumeric chars, Secret: 32+ alphanumeric chars
LIVEKIT_API_KEY=lk-your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret-minimum-32-chars

# FreeSWITCH ESL socket password — choose any strong password
ESL_PASSWORD=your-strong-esl-password

# PostgreSQL database password — choose any strong password
POSTGRES_PASSWORD=your-strong-postgres-password
